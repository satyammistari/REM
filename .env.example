# ─── Go API ───────────────────────────────────────────────────────────────────
# HTTP port for the Go REST API
PORT=8080

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rem
POSTGRES_PASSWORD=rem_password
POSTGRES_DB=rem_db
POSTGRES_SSL_MODE=disable

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6334
# Name of the Qdrant collection used for episode embeddings
QDRANT_COLLECTION=rem_episodes

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# ─── Python Worker ────────────────────────────────────────────────────────────
# Base URL the Go API uses to call the Python worker
PYTHON_WORKER_URL=http://localhost:8001

# Celery broker (Redis)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# ─── Security ─────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens
JWT_SECRET=change_me_in_production
# Default API key for development (header: X-API-Key)
API_KEY=rem_dev_key

# ─── Dashboard (Next.js public vars) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
